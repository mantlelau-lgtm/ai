{
  "rules": [
    {
      "id": "help",
      "priority": 100,
      "match": {
        "kind": "message",
        "text_prefix": "/help"
      },
      "action": {
        "reply_text": "欢迎使用 message-gateway。\n当前已接入渠道：Lark Bot。\n可用命令：\n- /help 查看帮助\n- 其他任意文本会触发默认回声回复。"
      }
    },
    {
      "id": "card_submit",
      "priority": 100,
      "match": {
        "kind": "card_action",
        "action_name": "submit"
      },
      "action": {
        "toast_text": "已提交，处理中",
        "reply_text": "已收到你的提交，稍后会更新处理结果。"
      }
    }
  ]
}
