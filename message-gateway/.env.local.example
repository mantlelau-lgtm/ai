HTTP_ADDR=:50082
DATABASE_URL=postgres://postgres:postgres123@127.0.0.1:5432/message_gateway?sslmode=disable

LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
LARK_VERIFICATION_TOKEN=xxx
LARK_ENCRYPT_KEY=xxx
LARK_OPEN_BASE_URL=https://open.larksuite.com
ADMIN_CONFIG_BASE_URL=http://127.0.0.1:50083
AGENT_CENTER_BASE_URL=http://127.0.0.1:9999
LLM_GATEWAY_BASE_URL=http://127.0.0.1:50080
AGENT_SELECTOR_MODEL=deepseek-chat
AGENT_SELECTOR_KEY_NAME=
AGENT_SELECTOR_TIMEOUT=20s
AGENT_UNAVAILABLE_REPLY_TEXT=当前没有可用的 agent，请稍后再试。
LARK_WS_ENABLED=true
LARK_STREAMING_CARD_ENABLED=true
LARK_STREAMING_CARD_UPDATE_INTERVAL=400ms
LARK_STREAMING_CARD_MAX_BYTES=20480

CORE_BASE_URL=http://localhost:50081
CORE_STREAM_PATH=/v1/messages:stream
CORE_TIMEOUT=60s
ROUTE_RULES_RELOAD_INTERVAL=2s

WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=8
WORKER_RETRY_BASE_INTERVAL=5s
